# ─── Portfolio Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in the values.
#
# None of these are required for the site to build/run locally —
# they enable optional production features.
# ──────────────────────────────────────────────────────────────────────

# Google site verification (Search Console)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Base URL override (defaults to https://mishalubich.com)
# NEXT_PUBLIC_BASE_URL=https://mishalubich.com

# Optional: enables AI-generated prompt critique on /tools.
# The prompt linter still works locally without this token.
# HUGGINGFACE_API_TOKEN=
# HUGGINGFACE_PROMPT_LINTER_MODEL=HuggingFaceH4/zephyr-7b-beta
